{
  "name": "hongteng-inventario",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de Gestión e Inventario — HONG TENG LTDA",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:types": "tsx scripts/generar-tipos.ts",
    "db:reset": "supabase db reset",
    "db:sql": "tsx scripts/generar-sql-completo.ts",
    "db:probar": "tsx scripts/probar-conexion.ts",
    "db:migrar": "tsx scripts/aplicar-migraciones.ts",
    "migrar:bodega": "tsx scripts/migrar-bodega.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.58.0",
    "lucide-react": "^1.26.0",
    "next": "^15.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.4",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.6.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
