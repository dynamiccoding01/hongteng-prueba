# ---------------------------------------------------------------------------
# Copiar a .env.local y completar. NUNCA commitear el archivo .env.local
# ---------------------------------------------------------------------------

# URL del proyecto Supabase (publica, llega al navegador)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave publica del proyecto (protegida por RLS, llega al navegador).
# Los proyectos nuevos la llaman "publishable key" (sb_publishable_...);
# los antiguos, "anon key". El codigo acepta cualquiera de los dos nombres.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave secreta: OMITE RLS.
# Solo para tareas de servidor. JAMAS en codigo de cliente.
SUPABASE_SECRET_KEY=

# Personal Access Token del panel (https://supabase.com/dashboard/account/tokens)
# Lo usa scripts/aplicar-migraciones.ts para ejecutar DDL via Management API.
# OJO: da acceso a todos tus proyectos. No compartir ni commitear.
SUPABASE_ACCESS_TOKEN=

# Ruta al archivo del cliente para el script de migracion inicial (ADM-04)
BODEGA_XLS_PATH=./datos/BODEGA.xls
