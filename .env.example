# ---------------------------------------------------------------------------
# Copiar a .env.local y completar. NUNCA commitear el archivo .env.local
# ---------------------------------------------------------------------------

# URL del proyecto Supabase (publica, llega al navegador)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave anonima (publica, protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio: OMITE RLS.
# Solo para scripts de migracion y tareas de servidor. JAMAS en codigo de cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Ruta al archivo del cliente para el script de migracion inicial (ADM-04)
BODEGA_XLS_PATH=./datos/BODEGA.xls
